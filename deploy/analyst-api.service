# systemd unit for the Automotive Analyst API (text-to-SQL gateway).
# Install: sudo cp deploy/analyst-api.service /etc/systemd/system/
#          sudo systemctl daemon-reload && sudo systemctl enable --now analyst-api
# Adjust User/Group and the paths below to your host. Binds to a loopback port
# (8010) behind nginx. No LLM key here - the only secret is the read-only
# DATABASE_URL in backend/.env, which is git-ignored.

[Unit]
Description=Automotive Analyst API (text-to-SQL)
After=network.target postgresql.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/automotive-analyst/backend
EnvironmentFile=/opt/automotive-analyst/backend/.env
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/automotive-analyst/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010 --workers 2
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
