# Backend (VPS) -- copy to backend/.env or set in the systemd unit.
# This service holds NO LLM API key: visitors bring their own key in the browser.

# READ-ONLY connection to the existing dashboard database.
DATABASE_URL=postgresql://factory_ro:CHANGEME@localhost:5432/manufacturing

# Allowed frontend origin(s) -- the Cloudflare Pages site.
CORS_ORIGINS=https://analyst.scottcampbell.io,http://localhost:3000

# Optional tunables (defaults shown).
# MAX_QUESTION_CHARS=500
# MAX_SQL_CHARS=4000
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_S=60
# QUERY_TIMEOUT_MS=5000
# LOG_LEVEL=INFO

# Frontend (Cloudflare Pages) build env -- set in the Pages project settings:
# NEXT_PUBLIC_API_BASE=https://analyst-api.scottcampbell.io
